{
    "name": "vandetho/laraflow",
    "description": "A Symfony-compatible workflow engine for Laravel. State machines, Petri nets, guards, events, validation, weighted arcs, middleware, and YAML/JSON/PHP import/export.",
    "keywords": [
        "laravel",
        "workflow",
        "state-machine",
        "petri-net",
        "symfony",
        "transitions",
        "guards",
        "events"
    ],
    "license": "MIT",
    "authors": [
        {
            "name": "Vandeth Tho",
            "email": "thovandeth@gmail.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/console": "^11.0|^12.0",
        "illuminate/events": "^11.0|^12.0",
        "symfony/yaml": "^6.4|^7.0"
    },
    "require-dev": {
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0",
        "pestphp/pest-plugin-laravel": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Laraflow\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Laraflow\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Laraflow\\LaraflowServiceProvider"
            ],
            "aliases": {
                "Laraflow": "Laraflow\\Facades\\Laraflow"
            }
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
